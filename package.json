{
  "name": "quartiplay-investment-platform",
  "version": "1.0.0",
  "description": "منصة استثمار رقمية Quartiplay",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm start",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "start": "node dist/server/index.js",
    "test": "jest",
    "lint": "eslint .",
    "migrate": "node database/migrate.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "pg": "^8.8.0",
    "uuid": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "stripe": "^11.0.0",
    "paypal-rest-sdk": "^1.7.1",
    "axios": "^1.3.0",
    "nodemailer": "^6.8.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/node": "^18.11.0",
    "@types/express": "^4.17.17",
    "typescript": "^4.9.0",
    "nodemon": "^2.0.20",
    "concurrently": "^7.5.0",
    "jest": "^29.3.0",
    "eslint": "^8.30.0",
    "prettier": "^2.8.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
